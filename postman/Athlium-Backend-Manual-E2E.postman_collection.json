{
  "info": {
    "name": "Athlium Backend - Manual E2E",
    "_postman_id": "f6f2dd52-1174-4f5d-a8a0-8f5f6f6df0f2",
    "description": "Manual flow collection for auth, gym config/scheduling, sessions, users, and bookings.\n\nBefore running:\n1) Start DBs: podman-compose -f podman-compose.yaml up -d\n2) Run backend: FIREBASE_MOCK_ENABLED=true ./mvnw quarkus:dev\n3) Set baseUrl if needed.\n\nAuth note (Firebase BFF):\n- Register/Login use email/password payloads.\n- Login/Register/Refresh scripts store accessToken and refreshToken automatically.\n- Use accessToken as Authorization Bearer token (Firebase ID token).\n- Call GET /api/auth/me to enrich identity with local userId/roles.\n\nCurrent API notes:\n- Organization/Headquarters GET endpoints are available to any authenticated user.\n- Headquarters GET includes nested activities and activity sessions.\n- Users list supports headquartersId and hq alias; do not combine headquarters and organization filters.\n- Booking create/list/cancel is self-only for CLIENT and cross-user for staff/admin roles.\n- Session responses include participants entries with id, name, lastName, and email.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "authEmail", "value": "tester-001@example.com" },
    { "key": "authPassword", "value": "ChangeMe123!" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "organizationId", "value": "1" },
    { "key": "headquartersId", "value": "1" },
    { "key": "activityId", "value": "1" },
    { "key": "sessionId", "value": "" },
    { "key": "localUserId", "value": "1" },
    { "key": "bookingId1", "value": "" },
    { "key": "bookingId2", "value": "" },
    { "key": "bookingId3", "value": "" },
    { "key": "idemBooking1", "value": "bk-req-1" },
    { "key": "idemBooking2", "value": "bk-req-2" },
    { "key": "idemBooking3", "value": "bk-req-3" },
    { "key": "idemCancel1", "value": "bk-cancel-1" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "description": "Frontend auth flow:\\n1) Register or login with credentials (email/password).\\n2) Use returned accessToken as Bearer token.\\n3) Refresh with refreshToken when needed.\\n4) Fetch /api/auth/me to get local roles and userId.",
      "item": [
        {
          "name": "Auth Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/health"
          }
        },
        {
          "name": "Login (Credentials)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r?.data?.needsRegistration === true) {",
                  "  pm.collectionVariables.set('accessToken', '');",
                  "  pm.collectionVariables.set('refreshToken', '');",
                  "}",
                  "if (r?.data?.user?.userId) pm.collectionVariables.set('localUserId', String(r.data.user.userId));",
                  "if (r && r.data && r.data.tokens) {",
                  "  pm.collectionVariables.set('accessToken', r.data.tokens.accessToken || '');",
                  "  pm.collectionVariables.set('refreshToken', r.data.tokens.refreshToken || '');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Register (Credentials)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r?.data?.user?.userId) pm.collectionVariables.set('localUserId', String(r.data.user.userId));",
                  "if (r && r.data && r.data.tokens) {",
                  "  pm.collectionVariables.set('accessToken', r.data.tokens.accessToken || '');",
                  "  pm.collectionVariables.set('refreshToken', r.data.tokens.refreshToken || '');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\",\n  \"name\": \"Test\",\n  \"lastName\": \"User\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r && r.data && r.data.tokens) {",
                  "  pm.collectionVariables.set('accessToken', r.data.tokens.accessToken || '');",
                  "  pm.collectionVariables.set('refreshToken', r.data.tokens.refreshToken || '');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/refresh"
          }
        },
        {
          "name": "Me (Identity + Local Roles)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "const id = r?.data?.user?.userId;",
                  "if (id) pm.collectionVariables.set('localUserId', String(id));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "2. Gym Bootstrap (REST)",
      "item": [
        {
          "name": "Create Organization",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "const id = r?.data?.id;",
                  "if (id) pm.collectionVariables.set('organizationId', String(id));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Gym Demo\"\n}"
            },
            "url": "{{baseUrl}}/api/organizations"
          }
        },
        {
          "name": "Create Headquarters",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "const id = r?.data?.id;",
                  "if (id) pm.collectionVariables.set('headquartersId', String(id));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organizationId\": {{organizationId}},\n  \"name\": \"HQ Centro\"\n}"
            },
            "url": "{{baseUrl}}/api/headquarters"
          }
        },
        {
          "name": "Create Activity",
          "description": "Requires SUPERADMIN, ORG_OWNER, ORG_ADMIN, or PROFESSOR role.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "const id = r?.data?.id;",
                  "if (id) pm.collectionVariables.set('activityId', String(id));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cross Training\",\n  \"description\": \"Clase funcional\",\n  \"hqId\": {{headquartersId}}\n}"
            },
            "url": "{{baseUrl}}/api/activities"
          }
        }
      ]
    },
    {
      "name": "3. Gym Config",
      "item": [
        {
          "name": "Upsert Activity Config",
          "description": "Requires SUPERADMIN, ORG_OWNER, ORG_ADMIN, or PROFESSOR role.",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"maxParticipants\": 2,\n  \"waitlistEnabled\": true,\n  \"waitlistMaxSize\": 3,\n  \"waitlistStrategy\": \"FIFO\",\n  \"cancellationMinHoursBeforeStart\": 2,\n  \"cancellationAllowLateCancel\": true\n}"
            },
            "url": "{{baseUrl}}/api/gym/config/activities/{{activityId}}"
          }
        },
        {
          "name": "Get Effective Config",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/gym/config/effective?organizationId={{organizationId}}&headquartersId={{headquartersId}}&activityId={{activityId}}"
          }
        }
      ]
    },
    {
      "name": "4. Schedules and Sessions",
      "item": [
        {
          "name": "Create Activity Schedule",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organizationId\": {{organizationId}},\n  \"headquartersId\": {{headquartersId}},\n  \"activityId\": {{activityId}},\n  \"dayOfWeek\": 1,\n  \"startTime\": \"18:00\",\n  \"durationMinutes\": 60,\n  \"active\": true\n}"
            },
            "url": "{{baseUrl}}/api/activity-schedules"
          }
        },
        {
          "name": "Generate Next Week Sessions",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/activity-schedules/generate-next-week"
          }
        },
        {
          "name": "List Sessions (Set sessionId)",
          "description": "Returns session list including participants[]. Each participant exposes id, name, lastName, email.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "const first = r?.data?.items?.[0];",
                  "if (first?.id) pm.collectionVariables.set('sessionId', String(first.id));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/sessions?organizationId={{organizationId}}&headquartersId={{headquartersId}}&activityId={{activityId}}&page=1&limit=20"
          }
        },
        {
          "name": "Get Session by ID",
          "description": "Session detail includes participants[].",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/sessions/{{sessionId}}"
          }
        }
      ]
    },
    {
      "name": "5. Users Access Rules",
      "description": "Covers updated user query filters and preferred role update by internal user id.",
      "item": [
        {
          "name": "List Users by headquartersId",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users?headquartersId={{headquartersId}}&page=1&size=20&sort=name:asc"
          }
        },
        {
          "name": "List Users by hq alias",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users?hq={{headquartersId}}&page=1&size=20&sort=name:asc"
          }
        },
        {
          "name": "Get User by localUserId",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/{{localUserId}}"
          }
        },
        {
          "name": "Update Roles by userId (preferred)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roles\": [\"CLIENT\"]\n}"
            },
            "url": "{{baseUrl}}/api/users/{{localUserId}}/roles"
          }
        }
      ]
    },
    {
      "name": "6. Bookings",
      "description": "CLIENT can only manage own bookings (use localUserId). Staff/admin roles can manage bookings for other users.",
      "item": [
        {
          "name": "Create Booking Self",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "const id = r?.data?.id;",
                  "if (id) pm.collectionVariables.set('bookingId1', String(id));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{idemBooking1}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{localUserId}}\n}"
            },
            "url": "{{baseUrl}}/api/sessions/{{sessionId}}/bookings"
          }
        },
        {
          "name": "Create Booking Other User (Staff/Admin)",
          "description": "Requires PROFESSOR/ORG_ADMIN/ORG_OWNER/SUPERADMIN role.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "const id = r?.data?.id;",
                  "if (id) pm.collectionVariables.set('bookingId2', String(id));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{idemBooking2}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 102\n}"
            },
            "url": "{{baseUrl}}/api/sessions/{{sessionId}}/bookings"
          }
        },
        {
          "name": "Create Booking Other User Waitlist (Staff/Admin)",
          "description": "Requires elevated role and configured maxParticipants/waitlist.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "const id = r?.data?.id;",
                  "if (id) pm.collectionVariables.set('bookingId3', String(id));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{idemBooking3}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 103\n}"
            },
            "url": "{{baseUrl}}/api/sessions/{{sessionId}}/bookings"
          }
        },
        {
          "name": "List Bookings by Session",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/bookings?sessionId={{sessionId}}&userId={{localUserId}}&sort=createdAt:asc"
          }
        },
        {
          "name": "Cancel Booking 1 (Promote Waitlist)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Idempotency-Key", "value": "{{idemCancel1}}" }
            ],
            "url": "{{baseUrl}}/api/bookings/{{bookingId1}}/cancel"
          }
        },
        {
          "name": "Replay Same Cancel (Idempotent)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Idempotency-Key", "value": "{{idemCancel1}}" }
            ],
            "url": "{{baseUrl}}/api/bookings/{{bookingId1}}/cancel"
          }
        },
        {
          "name": "List Bookings Final",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/bookings?sessionId={{sessionId}}&userId={{localUserId}}&sort=createdAt:asc"
          }
        }
      ]
    }
  ]
}
