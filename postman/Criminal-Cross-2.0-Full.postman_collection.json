{
  "info": {
    "name": "Criminal-Cross-2.0 Full API",
    "description": "Complete importable Postman collection for Criminal-Cross-2.0 backend modules.\n\nAuth flow (Firebase BFF):\n1) Call POST /api/auth/register or POST /api/auth/login with email/password.\n2) Save data.tokens.accessToken as Bearer token (Firebase ID token).\n3) Use POST /api/auth/refresh with refresh token when access token expires.\n4) Use GET /api/auth/me to enrich identity with local userId/roles.\n\nError envelope notes:\n- Most endpoint-level validations return { success, message } with data = null.\n- Uncaught/centralized errors use GlobalExceptionMapper and include data.code (and data.details for validation errors).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearer_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "bearer_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "auth_email", "value": "demo.user@example.com" },
    { "key": "auth_password", "value": "ChangeMe123!" },
    { "key": "id_token", "value": "", "description": "DEPRECATED: only for /api/auth/verify-token (410 Gone). Do not use in frontend flows." },
    { "key": "firebase_uid", "value": "demo-uid-001", "description": "Used by firebase UID compatibility routes." },
    { "key": "user_id", "value": "1" },
    { "key": "local_user_id", "value": "1", "description": "Authenticated local user id from /api/auth/me. Use this for self-service booking calls." },
    { "key": "organization_id", "value": "1" },
    { "key": "headquarters_id", "value": "1" },
    { "key": "activity_id", "value": "1" },
    { "key": "activity_schedule_id", "value": "1" },
    { "key": "session_id", "value": "1" },
    { "key": "booking_id", "value": "1" },
    { "key": "payment_id", "value": "1" },
    { "key": "client_package_id", "value": "1" },
    { "key": "idempotency_key", "value": "req-001" }
  ],
  "item": [
    {
      "name": "01 Auth",
      "description": "Frontend auth contract (current):\\n- Register/Login with credentials payload (email/password).\\n- Use data.tokens.accessToken as Authorization Bearer token (Firebase ID token).\\n- Refresh with data.tokens.refreshToken via /api/auth/refresh.\\n- Call /api/auth/me after login/refresh to get local enrichment (userId, roles, active, registered).\\n\\nDeprecated:\\n- /api/auth/verify-token returns 410 and should not be used.",
      "item": [
        {
          "name": "Health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{base_url}}/api/auth/health"
          }
        },
        {
          "name": "Verify Token (DEPRECATED - 410)",
          "description": "Deprecated endpoint. Kept only for backward compatibility checks. Expected status: 410 Gone.",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{id_token}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/verify-token"
          },
          "response": [
            {
              "name": "Deprecated",
              "status": "Gone",
              "code": 410,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": false,\n  \"message\": \"Endpoint deprecated. Use /api/auth/me with Authorization: Bearer <firebase-id-token>\"\n}"
            }
          ]
        },
        {
          "name": "Register",
          "description": "Registers a Firebase account through backend intermediary and creates local user profile. Returns Firebase token pair plus local user data.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const data = body && body.data ? body.data : {};",
                  "const tokens = data.tokens || {};",
                  "if (tokens.accessToken) pm.collectionVariables.set('bearer_token', tokens.accessToken);",
                  "if (tokens.refreshToken) pm.collectionVariables.set('refresh_token', tokens.refreshToken);",
                  "if (data.user && data.user.userId) { pm.collectionVariables.set('user_id', String(data.user.userId)); pm.collectionVariables.set('local_user_id', String(data.user.userId)); }",
                  "if (data.user && data.user.firebaseUid) pm.collectionVariables.set('firebase_uid', String(data.user.firebaseUid));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{auth_email}}\",\n  \"password\": \"{{auth_password}}\",\n  \"name\": \"Demo\",\n  \"lastName\": \"User\"\n}"
            },
            "url": "{{base_url}}/api/auth/register"
          },
          "response": [
            {
              "name": "Created",
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"message\": \"User registered successfully\",\n  \"data\": {\n    \"user\": {\n      \"firebaseUid\": \"firebase-uid-123\",\n      \"email\": \"demo.user@example.com\",\n      \"name\": \"Demo\",\n      \"roles\": [\"CLIENT\"],\n      \"registered\": true,\n      \"active\": true\n    },\n    \"tokens\": {\n      \"accessToken\": \"eyJhbGciOi...\",\n      \"refreshToken\": \"refresh-token-value\",\n      \"expiresIn\": 3600,\n      \"tokenType\": \"Bearer\"\n    },\n    \"message\": \"User registered successfully\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Login",
          "description": "Authenticates with Firebase credentials through backend intermediary. Use data.tokens.accessToken as Authorization Bearer token.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const data = body && body.data ? body.data : {};",
                  "const tokens = data.tokens || {};",
                  "if (tokens.accessToken) pm.collectionVariables.set('bearer_token', tokens.accessToken);",
                  "if (tokens.refreshToken) pm.collectionVariables.set('refresh_token', tokens.refreshToken);",
                  "if (data.user && data.user.userId) { pm.collectionVariables.set('user_id', String(data.user.userId)); pm.collectionVariables.set('local_user_id', String(data.user.userId)); }",
                  "if (data.user && data.user.firebaseUid) pm.collectionVariables.set('firebase_uid', String(data.user.firebaseUid));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{auth_email}}\",\n  \"password\": \"{{auth_password}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/login"
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"user\": {\n      \"firebaseUid\": \"firebase-uid-123\",\n      \"email\": \"demo.user@example.com\",\n      \"name\": \"Demo User\",\n      \"userId\": 42,\n      \"roles\": [\"CLIENT\"],\n      \"registered\": true,\n      \"active\": true\n    },\n    \"tokens\": {\n      \"accessToken\": \"eyJhbGciOi...\",\n      \"refreshToken\": \"refresh-token-value\",\n      \"expiresIn\": 3600,\n      \"tokenType\": \"Bearer\"\n    },\n    \"message\": \"Login successful\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Refresh",
          "description": "Exchanges refresh token for a new Firebase token pair. Update both bearer_token and refresh_token from response.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const tokens = body && body.data && body.data.tokens ? body.data.tokens : {};",
                  "if (tokens.accessToken) pm.collectionVariables.set('bearer_token', tokens.accessToken);",
                  "if (tokens.refreshToken) pm.collectionVariables.set('refresh_token', tokens.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/refresh"
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"user\": {\n      \"firebaseUid\": \"firebase-uid-123\",\n      \"email\": \"demo.user@example.com\",\n      \"userId\": 42,\n      \"roles\": [\"CLIENT\"],\n      \"registered\": true\n    },\n    \"tokens\": {\n      \"accessToken\": \"eyJhbGciOi...new\",\n      \"refreshToken\": \"refresh-token-value-new\",\n      \"expiresIn\": 3600,\n      \"tokenType\": \"Bearer\"\n    },\n    \"message\": \"Token refreshed successfully\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Me",
          "description": "Returns authenticated Firebase identity enriched with local Athlium user fields (userId, roles, registered, active).",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const user = body && body.data ? body.data.user : null;",
                  "if (user && user.userId) { pm.collectionVariables.set('local_user_id', String(user.userId)); pm.collectionVariables.set('user_id', String(user.userId)); }",
                  "if (user && user.firebaseUid) pm.collectionVariables.set('firebase_uid', String(user.firebaseUid));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearer_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{base_url}}/api/auth/me"
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"user\": {\n      \"firebaseUid\": \"firebase-uid-123\",\n      \"email\": \"demo.user@example.com\",\n      \"name\": \"Demo User\",\n      \"userId\": 42,\n      \"roles\": [\"CLIENT\", \"ORG_ADMIN\"],\n      \"registered\": true,\n      \"active\": true\n    },\n    \"needsRegistration\": false,\n    \"message\": \"Current user retrieved successfully\"\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "02 Users",
      "description": "Users API coverage:\n- Query endpoints include SUPERADMIN, ORG_ADMIN, ORG_OWNER.\n- GET /api/users supports headquartersId and hq alias (must match if both are sent).\n- Users can be filtered by headquarters OR organization, never both at once.\n- User headquarters payload now returns [{ id, name, organization: { id, name } }].\n- Preferred full update route uses internal ID: PUT /api/users/{id}.\n- Preferred role update route uses internal ID: PUT /api/users/{id}/roles (firebase UID variant remains for compatibility).\n- Role assignment matrix: ORG_OWNER -> ORG_ADMIN/PROFESSOR/CLIENT, ORG_ADMIN -> PROFESSOR/CLIENT, SUPERADMIN -> unrestricted.\n- HQ membership updates allow self-assign/remove; managing others requires org-scoped admin/owner or SUPERADMIN.",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const data = body && body.data ? body.data : {};",
                  "if (data.id) pm.collectionVariables.set('user_id', String(data.id));",
                  "if (data.firebaseUid) pm.collectionVariables.set('firebase_uid', String(data.firebaseUid));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firebaseUid\": \"{{firebase_uid}}\",\n  \"email\": \"demo+{{firebase_uid}}@example.com\",\n  \"name\": \"Demo\",\n  \"lastName\": \"User\"\n}"
            },
            "url": "{{base_url}}/api/users"
          }
        },
        {
          "name": "Get User By Firebase UID (Lookup)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/users/firebase/{{firebase_uid}}"
          }
        },
        {
          "name": "List Users (headquartersId)",
          "description": "Primary headquarters filter. Equivalent to hq alias.",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/users?headquartersId={{headquarters_id}}&status=active&search=demo&page=1&size=20&sort=name:asc"
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"message\": \"Users retrieved\",\n  \"data\": {\n    \"items\": [\n      {\n        \"id\": 42,\n        \"name\": \"Demo\",\n        \"lastName\": \"User\",\n        \"email\": \"demo.user@example.com\",\n        \"roles\": [\"CLIENT\"],\n        \"headquarters\": [\n          {\n            \"id\": 7,\n            \"name\": \"Central Branch\",\n            \"organization\": {\n              \"id\": 1,\n              \"name\": \"Criminal Cross HQ\"\n            }\n          }\n        ],\n        \"active\": true,\n        \"packageStatus\": \"ACTIVE\",\n        \"periodEnd\": \"2026-04-10\",\n        \"daysRemaining\": 28\n      }\n    ],\n    \"page\": 1,\n    \"size\": 20,\n    \"total\": 1\n  }\n}"
            }
          ]
        },
        {
          "name": "List Users (hq alias)",
          "description": "Alias for headquartersId filter. If both headquartersId and hq are present, they must match.",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/users?hq={{headquarters_id}}&page=1&size=20&sort=name:asc"
          }
        },
        {
          "name": "List Users (organizationId)",
          "description": "Use organizationId when querying users by organization scope.",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/users?organizationId={{organization_id}}&page=1&size=20&sort=name:asc"
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/users/{{user_id}}"
          }
        },
        {
          "name": "Update User By ID (Preferred)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo.updated+{{user_id}}@example.com\",\n  \"name\": \"Demo Updated\",\n  \"lastName\": \"User Updated\",\n  \"active\": true\n}"
            },
            "url": "{{base_url}}/api/users/{{user_id}}"
          }
        },
        {
          "name": "Update User By Firebase UID (Legacy Compatibility)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo.legacy+{{firebase_uid}}@example.com\",\n  \"name\": \"Legacy Update\",\n  \"lastName\": \"Compatibility\",\n  \"active\": true\n}"
            },
            "url": "{{base_url}}/api/users/firebase/{{firebase_uid}}"
          }
        },
        {
          "name": "Update User Roles By ID (Preferred)",
          "description": "Role assignment matrix: SUPERADMIN can assign any role; ORG_OWNER can assign ORG_ADMIN/PROFESSOR/CLIENT; ORG_ADMIN can assign PROFESSOR/CLIENT.",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roles\": [\"CLIENT\", \"PROFESSOR\"]\n}"
            },
            "url": "{{base_url}}/api/users/{{user_id}}/roles"
          }
        },
        {
          "name": "Update User Roles By Firebase UID (Legacy Compatibility)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roles\": [\"CLIENT\", \"PROFESSOR\"]\n}"
            },
            "url": "{{base_url}}/api/users/firebase/{{firebase_uid}}/roles"
          }
        },
        {
          "name": "Assign User To Headquarters",
          "description": "Self-assign is allowed. Managing other users requires org-scoped ORG_ADMIN/ORG_OWNER or SUPERADMIN.",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/users/firebase/{{firebase_uid}}/headquarters/{{headquarters_id}}"
          }
        },
        {
          "name": "Remove User From Headquarters",
          "description": "Self-remove is allowed. Managing other users requires org-scoped ORG_ADMIN/ORG_OWNER or SUPERADMIN.",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/users/firebase/{{firebase_uid}}/headquarters/{{headquarters_id}}"
          }
        },
        {
          "name": "Sync User With Firebase (DEPRECATED)",
          "description": "Deprecated for frontend auth flows. Use /api/auth/register and /api/auth/me instead of manually syncing users.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const data = body && body.data ? body.data : {};",
                  "if (data.id) pm.collectionVariables.set('user_id', String(data.id));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firebaseUid\": \"{{firebase_uid}}\",\n  \"email\": \"demo+{{firebase_uid}}@example.com\",\n  \"name\": \"Demo\",\n  \"lastName\": \"User\"\n}"
            },
            "url": "{{base_url}}/api/users/sync"
          }
        }
      ]
    },
